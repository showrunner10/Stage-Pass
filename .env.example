# Runtime connection (Supabase pooler; Vercel-safe)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection for Prisma CLI (migrate/db push)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Tracking and privacy
TRACKING_HASH_SALT="replace-with-strong-random-value"

# App URL (used in auth redirects like Google OAuth and forgot-password).
# For a Vercel client demo without a custom domain, use the exact Vercel deployment URL.
# Example: NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
# Local development only: set this to "http://localhost:3000" in your own .env.local.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# Supabase Auth (login/signup) - Dashboard -> Project Settings -> API
# Project URL and the "anon" / "publishable" public key (not the service_role secret).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<anon-public-key>"
# Optional alias supported by the app if your Supabase dashboard labels this as the anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
# Optional server-side aliases supported on Vercel/Supabase integrations.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Instant signup->login locally: Supabase Dashboard -> Authentication -> Providers -> Email -> disable "Confirm email".
#
# Google OAuth for this app is configured in Supabase Dashboard, not in app env.
# Google Cloud OAuth client should use:
# - Authorized JavaScript origins: your Vercel deployment origin
# - Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Then paste the Google Client ID + Client Secret into Supabase Dashboard -> Authentication -> Providers -> Google.
# In Supabase Dashboard -> Authentication -> URL Configuration, set:
# - Site URL: your Vercel deployment URL
# - Redirect URLs: https://your-project.vercel.app/api/auth/oauth/callback
# Do not use localhost in Vercel/Supabase settings for a client demo.

# Local-only: skip Supabase session in middleware so /app loads without login. Never set in production.
# STAGEPASS_DEV_AUTH_BYPASS=1

# Integration secrets
TIXR_WEBHOOK_SECRET="replace-with-long-secret"
ORDER_IMPORT_TOKEN="replace-with-import-token"
PAYOUT_JOB_TOKEN="replace-with-job-token"

# SMTP / support email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="you@gmail.com"
SMTP_PASS="replace-with-app-password"
SMTP_FROM="Hypelist <you@gmail.com>"
SUPPORT_INBOX="showrunner2026.io@gmail.com"
