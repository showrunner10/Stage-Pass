# Runtime connection (Supabase pooler; Vercel-safe)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection for Prisma CLI (migrate/db push)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Tracking and privacy
TRACKING_HASH_SALT="replace-with-strong-random-value"

# App URL (used in auth redirects like forgot-password)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (login/signup) — Dashboard → Project Settings → API
# Project URL and the "anon" / "publishable" public key (not the service_role secret).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Instant signup→login locally: Supabase Dashboard → Authentication → Providers → Email → disable "Confirm email".

# Local-only: skip Supabase session in middleware so /app loads without login. Never set in production.
# STAGEPASS_DEV_AUTH_BYPASS=1

# Integration secrets
TIXR_WEBHOOK_SECRET="replace-with-long-secret"
ORDER_IMPORT_TOKEN="replace-with-import-token"
PAYOUT_JOB_TOKEN="replace-with-job-token"

# SMTP / support email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="you@gmail.com"
SMTP_PASS="replace-with-app-password"
SMTP_FROM="Stagepass <you@gmail.com>"
SUPPORT_INBOX="hello@stagepass.com.au"
